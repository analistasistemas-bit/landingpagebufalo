---
// ColorRing.astro — Hero signature: colored dots in a ring with center medallion.
// Vivid, evenly-spaced HSL spectrum (the approved concept). The real/authentic
// catalog colors live in ColorSwatches (Linha 120 cartela), not here.
// Dots computed at build time (no client JS). Animation respects prefers-reduced-motion.

interface Props {
  dotCount?: number;
  label?: string;
  sublabel?: string;
}

const {
  dotCount = 24,
  label = '100+',
  sublabel = 'CORES',
} = Astro.props;

// Vivid spectrum: evenly-spaced hues, high saturation — a clean rainbow ring.
const dots = Array.from({ length: dotCount }, (_, i) => {
  const angle = (i / dotCount) * 2 * Math.PI - Math.PI / 2; // start top
  const rx = 43; // % from center
  const ry = 43;
  const cx = 50 + rx * Math.cos(angle);
  const cy = 50 + ry * Math.sin(angle);
  const hue = Math.round((i / dotCount) * 360);
  const color = `hsl(${hue}, 78%, 52%)`;
  return { cx, cy, color, delay: i * 55 }; // 55ms stagger
});
---

<div class="color-ring" role="img" aria-label={`Anel de ${dotCount} cores — ${label} ${sublabel}`}>
  <div class="color-ring__track">
    {dots.map((dot, i) => (
      <span
        class="color-ring__dot"
        style={`left:${dot.cx}%;top:${dot.cy}%;background-color:${dot.color};--delay:${dot.delay}ms`}
        aria-hidden="true"
      />
    ))}
    <div class="color-ring__medallion" aria-hidden="true">
      <span class="color-ring__label">{label}</span>
      <span class="color-ring__sublabel">{sublabel}</span>
    </div>
  </div>
</div>

<style>
  .color-ring {
    display: flex;
    align-items: center;
    justify-content: center;
    width: clamp(280px, 70vw, 400px);
    aspect-ratio: 1;
    flex-shrink: 0;
  }

  .color-ring__track {
    position: relative;
    width: 100%;
    height: 100%;
  }

  /* Dots */
  .color-ring__dot {
    position: absolute;
    width: clamp(16px, 4vw, 24px);
    height: clamp(16px, 4vw, 24px);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.25);
  }

  /* Center medallion */
  .color-ring__medallion {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);

    width: 44%;
    height: 44%;
    border-radius: 50%;

    background-color: var(--bufalo-vermelho);
    color: var(--bufalo-branco);

    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;

    box-shadow:
      0 0 0 3px var(--bufalo-branco),
      0 0 0 5px var(--bufalo-vermelho),
      0 4px 20px rgba(178, 34, 34, 0.45);
  }

  .color-ring__label {
    font-family: var(--font-titulo);
    font-weight: 800;
    font-size: clamp(1.1rem, 3.5vw, 1.6rem);
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .color-ring__sublabel {
    font-family: var(--font-titulo);
    font-weight: 600;
    font-size: clamp(0.5rem, 1.5vw, 0.75rem);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 2px;
    opacity: 0.9;
  }

  /* ── Animation (pop-in stagger) ── */
  /* Default: dots are visible (for reduced-motion users they stay static) */
  .color-ring__dot {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  @media (prefers-reduced-motion: no-preference) {
    .color-ring__dot {
      opacity: 0;
      transform: translate(-50%, -50%) scale(0);
      animation: dot-pop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
      animation-delay: var(--delay);
    }

    @keyframes dot-pop {
      to {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1);
      }
    }
  }
</style>
