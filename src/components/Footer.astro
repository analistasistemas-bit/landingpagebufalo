---
import { waLink, WA_NUMBER } from '../data/whatsapp';

const waHref = waLink();

const navLinks = [
  { label: 'Início',            href: '/' },
  { label: 'A Marca',           href: '/a-marca' },
  { label: 'Produtos',          href: '/produtos' },
  { label: 'Qualidade',         href: '/qualidade' },
  { label: 'Seja um Revendedor', href: '/revendedor' },
  { label: 'Contato',           href: '/contato' },
];

// Formatted for display: +55 81 98342-6557
const waDisplay = '+55 81 98342-6557';
---

<footer class="site-footer">
  <div class="container footer-inner">

    <!-- Col 1: Logo + tagline -->
    <div class="footer-col footer-brand">
      <a href="/" aria-label="Búfalo — página inicial">
        <img
          src="/images/logos/logo-branca.png"
          alt="Búfalo - Força e Qualidade"
          height="52"
          width="auto"
          loading="lazy"
        />
      </a>
      <p class="footer-tagline">Búfalo · Força e Qualidade</p>
      <p class="footer-desc">
        Linhas de costura e aviamentos de alta resistência. Presente em todo o Brasil.
      </p>
    </div>

    <!-- Col 2: Contato -->
    <div class="footer-col">
      <h3 class="footer-heading">Contato</h3>
      <ul class="footer-list">
        <li>
          <a
            href={waHref}
            target="_blank"
            rel="noopener noreferrer"
            class="footer-link footer-link--wa"
            aria-label={`WhatsApp ${waDisplay}`}
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            {waDisplay}
          </a>
        </li>
        <li>
          <span class="footer-placeholder">E-mail: [CONFIRMAR]</span>
        </li>
        <li>
          <span class="footer-placeholder">Redes sociais: [em breve]</span>
        </li>
      </ul>
    </div>

    <!-- Col 3: Links rápidos -->
    <div class="footer-col">
      <h3 class="footer-heading">Navegação</h3>
      <ul class="footer-list">
        {navLinks.map(({ label, href }) => (
          <li>
            <a href={href} class="footer-link">{label}</a>
          </li>
        ))}
      </ul>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="container">
      <p>© 2026 Linhas Búfalo · Todos os direitos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--bufalo-bordo);
    color: var(--bufalo-branco);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 3rem;
    padding-block: 3.5rem;
  }

  .footer-brand .footer-tagline {
    margin-top: 1rem;
    font-family: var(--font-titulo);
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #fff;
    margin-bottom: 0.5rem;
  }

  .footer-desc {
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.92);
    line-height: 1.6;
    margin-bottom: 0;
  }

  .footer-heading {
    font-family: var(--font-titulo);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 1rem;
  }

  .footer-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-link {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.15s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .footer-link:hover {
    color: var(--bufalo-branco);
    text-decoration: none;
  }

  .footer-link--wa {
    color: #4ade80; /* green-400 — visible on dark background */
  }

  .footer-link--wa:hover {
    color: #86efac;
  }

  .footer-placeholder {
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.82);
    font-style: italic;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    padding-block: 1.25rem;
  }

  .footer-bottom p {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.72);
    text-align: center;
    margin: 0;
  }

  /* Tablet */
  @media (max-width: 900px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  /* Mobile */
  @media (max-width: 540px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding-block: 2.5rem;
    }
  }
</style>
