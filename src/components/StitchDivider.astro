---
// StitchDivider.astro — Thin section divider evoking a sewing stitch line.
// Pure CSS. Optional IntersectionObserver reveal respects prefers-reduced-motion.

interface Props {
  color?: string;
  ornament?: boolean;
}

const { color = 'var(--bufalo-vermelho)', ornament = true } = Astro.props;
---

<div class="stitch-divider" style={`--stitch-color:${color}`} aria-hidden="true">
  <div class="stitch-divider__line"></div>
  {ornament && (
    <div class="stitch-divider__ornament">
      <!-- Small scissors-like ornament (two triangles) -->
      <svg width="20" height="14" viewBox="0 0 20 14" fill="none" aria-hidden="true">
        <circle cx="4" cy="4" r="3" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <circle cx="4" cy="10" r="3" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <line x1="6.5" y1="5.5" x2="19" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="6.5" y1="8.5" x2="19" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </div>
  )}
</div>

<style>
  .stitch-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: 0.25rem;
    width: 100%;
    color: var(--stitch-color, var(--bufalo-vermelho));
    position: relative;
  }

  .stitch-divider__line {
    flex: 1;
    height: 0;
    border-top: 2px dashed var(--stitch-color, var(--bufalo-vermelho));
    opacity: 0.4;
    /* Scroll reveal: start short, expand to full */
    transform-origin: left center;
  }

  .stitch-divider__ornament {
    flex-shrink: 0;
    padding-inline: 0.75rem;
    opacity: 0.7;
    color: var(--stitch-color, var(--bufalo-vermelho));
  }

  .stitch-divider__ornament svg {
    display: block;
  }

  /* Scroll reveal: element fades in when visible */
  .stitch-divider {
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  .stitch-divider.is-visible {
    opacity: 1;
  }

  /* Reduced motion: always visible, no transition */
  @media (prefers-reduced-motion: reduce) {
    .stitch-divider {
      opacity: 1;
      transition: none;
    }
  }
</style>

<script>
  // Lightweight IntersectionObserver reveal — respects prefers-reduced-motion
  const mq = window.matchMedia('(prefers-reduced-motion: no-preference)');

  if (mq.matches) {
    const dividers = document.querySelectorAll<HTMLElement>('.stitch-divider');
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2 }
    );
    dividers.forEach((el) => observer.observe(el));
  } else {
    // Reduced motion: mark all visible immediately
    document.querySelectorAll('.stitch-divider').forEach((el) => {
      el.classList.add('is-visible');
    });
  }
</script>
