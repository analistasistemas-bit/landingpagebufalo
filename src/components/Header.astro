---
import { waLink } from '../data/whatsapp';

const navLinks = [
  { label: 'Início',            href: '/' },
  { label: 'A Marca',           href: '/a-marca' },
  { label: 'Produtos',          href: '/produtos' },
  { label: 'Qualidade',         href: '/qualidade' },
  { label: 'Seja um Revendedor', href: '/revendedor' },
  { label: 'Contato',           href: '/contato' },
];

const currentPath = Astro.url.pathname;
const waHref = waLink();
---

<header class="site-header" id="site-header">
  <div class="container header-inner">
    <!-- Logo -->
    <a href="/" class="header-logo" aria-label="Búfalo — página inicial">
      <img
        src="/images/logos/logo-v2.png"
        alt="Búfalo - Força e Qualidade"
        height="44"
        width="auto"
        loading="eager"
      />
    </a>

    <!-- Nav principal (desktop) -->
    <nav
      class="header-nav"
      id="header-nav"
      aria-label="Navegação principal"
    >
      <ul role="list">
        {navLinks.map(({ label, href }) => {
          const isActive =
            href === '/'
              ? currentPath === '/'
              : currentPath.startsWith(href);
          return (
            <li>
              <a
                href={href}
                class:list={['nav-link', { active: isActive }]}
                aria-current={isActive ? 'page' : undefined}
              >
                {label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <!-- CTA WhatsApp -->
    <a
      href={waHref}
      class="btn btn--primary header-cta"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Fale conosco no WhatsApp"
    >
      <!-- WhatsApp icon (inline SVG, minimal) -->
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      WhatsApp
    </a>

    <!-- Hamburger (mobile) -->
    <button
      class="hamburger"
      id="hamburger"
      aria-label="Abrir menu de navegação"
      aria-expanded="false"
      aria-controls="header-nav"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>
</header>

<script>
  const hamburger = document.getElementById('hamburger') as HTMLButtonElement;
  const nav = document.getElementById('header-nav') as HTMLElement;
  const header = document.getElementById('site-header') as HTMLElement;

  // Toggle mobile menu
  hamburger?.addEventListener('click', () => {
    const isOpen = nav.classList.toggle('is-open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
    hamburger.setAttribute(
      'aria-label',
      isOpen ? 'Fechar menu de navegação' : 'Abrir menu de navegação'
    );
  });

  // Close menu on nav link click (mobile)
  nav?.querySelectorAll('.nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      nav.classList.remove('is-open');
      hamburger.setAttribute('aria-expanded', 'false');
      hamburger.setAttribute('aria-label', 'Abrir menu de navegação');
    });
  });

  // Shadow on scroll
  window.addEventListener('scroll', () => {
    header.classList.toggle('scrolled', window.scrollY > 4);
  }, { passive: true });
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: var(--bufalo-branco);
    transition: box-shadow 0.2s ease;
  }

  .site-header.scrolled {
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.12);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 64px;
  }

  .header-logo img {
    height: 44px;
    width: auto;
    display: block;
  }

  /* Desktop nav */
  .header-nav ul {
    display: flex;
    list-style: none;
    gap: 0.25rem;
    align-items: center;
  }

  .nav-link {
    display: block;
    padding: 0.4rem 0.65rem;
    font-family: var(--font-titulo);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--bufalo-cinza);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--bufalo-vermelho);
    text-decoration: none;
  }

  .nav-link.active {
    color: var(--bufalo-vermelho);
    border-bottom-color: var(--bufalo-vermelho);
  }

  /* CTA button */
  .header-cta {
    font-size: 0.85rem;
    padding: 0.5rem 1rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .hamburger-line {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--bufalo-cinza);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hamburger {
      display: flex;
    }

    .header-cta {
      display: none;
    }

    .header-nav {
      display: none;
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      background-color: var(--bufalo-branco);
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
      padding: 1rem 0 1.5rem;
    }

    .header-nav.is-open {
      display: block;
    }

    .header-nav ul {
      flex-direction: column;
      gap: 0;
      align-items: stretch;
    }

    .nav-link {
      padding: 0.85rem 1.5rem;
      font-size: 1rem;
      border-bottom: none;
      border-left: 3px solid transparent;
    }

    .nav-link:hover,
    .nav-link.active {
      background-color: var(--bufalo-cinza-claro);
      border-left-color: var(--bufalo-vermelho);
    }
  }

  /* Ensure header space for sticky */
  :global(body) {
    padding-top: 64px;
  }
</style>
