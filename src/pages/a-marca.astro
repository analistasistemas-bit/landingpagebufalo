---
import BaseLayout from '../layouts/BaseLayout.astro';
import { seo } from '../data/seo';
import { waLink } from '../data/whatsapp';
import StitchDivider from '../components/StitchDivider.astro';
import CTASection from '../components/CTASection.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('paginas', 'a-marca');
const c = page.data;
---

<BaseLayout title={seo.marca.title} description={seo.marca.description}>

  <!-- 1. ABERTURA -->
  <section class="marca-hero">
    <div class="container">
      <h1 class="marca-hero__title">{c.titulo}</h1>
      <p class="marca-hero__texto">
        {c.abertura}
      </p>
      <p class="marca-hero__credencial">
        Há mais de 20 anos no mercado, a Búfalo é referência em aviamentos para confecção e artesanato em todo o Brasil.
      </p>
    </div>
  </section>

  <StitchDivider />

  <!-- 2. MISSÃO · VISÃO · VALORES -->
  <section class="mvv">
    <div class="container">
      <div class="mvv__grid">

        <div class="mvv__card">
          <h2 class="mvv__card-title">Missão</h2>
          <p class="mvv__card-texto">
            {c.missaoTexto}
          </p>
        </div>

        <div class="mvv__card">
          <h2 class="mvv__card-title">Visão</h2>
          <p class="mvv__card-texto">
            {c.visaoTexto}
          </p>
        </div>

      </div>

      <!-- Valores -->
      <div class="valores">
        <h2 class="valores__heading">Valores</h2>
        <ul class="valores__grid" role="list">
          <li class="valores__item">
            <span class="valores__icon" aria-hidden="true">
              <!-- Shield -->
              <svg width="32" height="32" viewBox="0 0 40 40" fill="none">
                <path d="M20 4L6 10v10c0 8.284 5.928 16.025 14 18 8.072-1.975 14-9.716 14-18V10L20 4z"
                  stroke="currentColor" stroke-width="2.2" stroke-linejoin="round" fill="none"/>
                <path d="M14 20l4 4 8-8" stroke="currentColor" stroke-width="2.2"
                  stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <strong class="valores__nome">{c.valores![0].nome}</strong>
            <span class="valores__desc">{c.valores![0].desc}</span>
          </li>
          <li class="valores__item">
            <span class="valores__icon" aria-hidden="true">
              <!-- Star -->
              <svg width="32" height="32" viewBox="0 0 40 40" fill="none">
                <path d="M20 5l3.9 8.3 9 1.3-6.5 6.4 1.5 9-8-4.3-8 4.3 1.5-9L7.1 14.6l9-1.3L20 5z"
                  stroke="currentColor" stroke-width="2.2" stroke-linejoin="round" fill="none"/>
              </svg>
            </span>
            <strong class="valores__nome">{c.valores![1].nome}</strong>
            <span class="valores__desc">{c.valores![1].desc}</span>
          </li>
          <li class="valores__item">
            <span class="valores__icon" aria-hidden="true">
              <!-- Clock / tradition -->
              <svg width="32" height="32" viewBox="0 0 40 40" fill="none">
                <circle cx="20" cy="20" r="14" stroke="currentColor" stroke-width="2.2" fill="none"/>
                <path d="M20 12v8l5 3" stroke="currentColor" stroke-width="2.2"
                  stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <strong class="valores__nome">{c.valores![2].nome}</strong>
            <span class="valores__desc">{c.valores![2].desc}</span>
          </li>
          <li class="valores__item">
            <span class="valores__icon" aria-hidden="true">
              <!-- Palette -->
              <svg width="32" height="32" viewBox="0 0 40 40" fill="none">
                <circle cx="13" cy="13" r="5" stroke="currentColor" stroke-width="2.2" fill="none"/>
                <circle cx="27" cy="13" r="5" stroke="currentColor" stroke-width="2.2" fill="none"/>
                <circle cx="20" cy="25" r="5" stroke="currentColor" stroke-width="2.2" fill="none"/>
                <circle cx="13" cy="13" r="2" fill="currentColor"/>
                <circle cx="27" cy="13" r="2" fill="currentColor"/>
                <circle cx="20" cy="25" r="2" fill="currentColor"/>
              </svg>
            </span>
            <strong class="valores__nome">{c.valores![3].nome}</strong>
            <span class="valores__desc">{c.valores![3].desc}</span>
          </li>
          <li class="valores__item">
            <span class="valores__icon" aria-hidden="true">
              <!-- Map pin -->
              <svg width="32" height="32" viewBox="0 0 40 40" fill="none">
                <path d="M20 4C14.477 4 10 8.477 10 14c0 8.25 10 22 10 22s10-13.75 10-22c0-5.523-4.477-10-10-10z"
                  stroke="currentColor" stroke-width="2.2" fill="none"/>
                <circle cx="20" cy="14" r="3.5" stroke="currentColor" stroke-width="2" fill="none"/>
              </svg>
            </span>
            <strong class="valores__nome">{c.valores![4].nome}</strong>
            <span class="valores__desc">{c.valores![4].desc}</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <StitchDivider />

  <!-- 3. POSICIONAMENTO -->
  <section class="posicionamento">
    <div class="container posicionamento__inner">
      <h2 class="posicionamento__title">Posicionamento</h2>
      <blockquote class="posicionamento__frase">
        {c.posicionamentoFrase}
      </blockquote>
      <p class="posicionamento__texto">
        {c.posicionamentoTexto}
      </p>
    </div>
  </section>

  <StitchDivider />

  <!-- 4. PRESENÇA NACIONAL -->
  <section class="presenca">
    <div class="container presenca__inner">
      <span class="presenca__kicker">{c.presencaKicker}</span>
      <p class="presenca__texto">
        {c.presencaTexto}
      </p>
    </div>
  </section>

  <StitchDivider />

  <!-- 5. CTA FINAL -->
  <section class="marca-cta">
    <div class="container marca-cta__inner">
      <a href="/produtos" class="btn btn--primary">{c.ctaPrimario}</a>
      <a
        href={waLink()}
        class="btn btn--ghost-dark"
        target="_blank"
        rel="noopener noreferrer"
      >
        {c.ctaSecundario}
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── ABERTURA ── */
  .marca-hero {
    background-color: var(--bufalo-cinza);
    padding-block: 4rem;
  }

  .marca-hero .container {
    max-width: 760px;
  }

  .marca-hero__title {
    font-family: var(--font-titulo);
    font-size: clamp(2rem, 5vw, 3.4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.1;
    color: var(--bufalo-branco);
    margin-bottom: 1.25rem;
  }

  .marca-hero__texto {
    font-size: clamp(1rem, 2vw, 1.1rem);
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.7;
    margin-bottom: 1.75rem;
  }

  .marca-hero__credencial {
    font-size: clamp(0.95rem, 1.8vw, 1.05rem);
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.6;
    margin-bottom: 0;
  }

  /* ── MISSÃO · VISÃO ── */
  .mvv {
    padding-block: 3.5rem;
    background-color: var(--bufalo-branco);
  }

  .mvv__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 640px) {
    .mvv__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .mvv__card {
    background-color: var(--bufalo-cinza-claro);
    border-radius: var(--radius);
    padding: 1.75rem;
  }

  .mvv__card-title {
    font-family: var(--font-titulo);
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--bufalo-vermelho);
    margin-bottom: 0.75rem;
  }

  .mvv__card-texto {
    font-size: 0.97rem;
    color: #555;
    line-height: 1.65;
    margin: 0;
  }

  /* ── VALORES ── */
  .valores__heading {
    font-family: var(--font-titulo);
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--bufalo-cinza);
    margin-bottom: 1.75rem;
    text-align: center;
  }

  .valores__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 480px) {
    .valores__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .valores__grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  .valores__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.6rem;
    padding: 1.5rem 1rem;
    background-color: var(--bufalo-branco);
    border: 1px solid #e5e5e5;
    border-radius: var(--radius);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .valores__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background-color: rgba(178, 34, 34, 0.08);
    color: var(--bufalo-vermelho);
  }

  .valores__nome {
    font-family: var(--font-titulo);
    font-size: 0.95rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--bufalo-cinza);
  }

  .valores__desc {
    font-size: 0.83rem;
    color: #666;
    line-height: 1.5;
  }

  /* ── POSICIONAMENTO ── */
  .posicionamento {
    padding-block: 3.5rem;
    background-color: var(--bufalo-cinza-claro);
  }

  .posicionamento__inner {
    max-width: 700px;
    margin-inline: auto;
    text-align: center;
  }

  .posicionamento__title {
    font-family: var(--font-titulo);
    font-size: 0.82rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--bufalo-vermelho);
    margin-bottom: 1rem;
  }

  .posicionamento__frase {
    font-family: var(--font-titulo);
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--bufalo-cinza);
    line-height: 1.2;
    margin: 0 0 1.25rem;
    border: none;
    padding: 0;
  }

  .posicionamento__texto {
    font-size: 1rem;
    color: #555;
    line-height: 1.7;
    margin: 0;
  }

  /* ── PRESENÇA NACIONAL ── */
  .presenca {
    padding-block: 3rem;
    background-color: var(--bufalo-vermelho);
    color: var(--bufalo-branco);
  }

  .presenca__inner {
    text-align: center;
    max-width: 660px;
    margin-inline: auto;
  }

  .presenca__kicker {
    display: block;
    font-family: var(--font-titulo);
    font-size: clamp(1.4rem, 3.5vw, 2.2rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 1rem;
  }

  .presenca__texto {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.65;
    margin: 0;
  }

  /* ── CTA FINAL ── */
  .marca-cta {
    padding-block: 3rem;
    background-color: var(--bufalo-branco);
  }

  .marca-cta__inner {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  .btn--ghost-dark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7em 1.6em;
    border-radius: var(--radius);
    font-family: var(--font-titulo);
    font-weight: 700;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-decoration: none;
    border: 2px solid var(--bufalo-cinza);
    color: var(--bufalo-cinza);
    background: transparent;
    transition: background-color 0.15s, color 0.15s;
  }

  .btn--ghost-dark:hover {
    background-color: var(--bufalo-cinza);
    color: var(--bufalo-branco);
  }
</style>
