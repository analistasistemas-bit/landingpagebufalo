---
// TEMPORARY — Task 5 placeholder so the build has a page to render.
// Task 7 will replace this with the full Home (hero, ColorRing, sections, etc.)
import BaseLayout from '../layouts/BaseLayout.astro';
import { seo } from '../data/seo';
---

<BaseLayout title={seo.home.title} description={seo.home.description}>
  <section class="placeholder-hero">
    <div class="container">
      <h1>Búfalo</h1>
      <p>Força e Qualidade em cada carretel.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .placeholder-hero {
    min-height: 60vh;
    display: flex;
    align-items: center;
    background-color: var(--bufalo-cinza-claro);
  }

  .placeholder-hero h1 {
    color: var(--bufalo-vermelho);
    margin-bottom: 0.5rem;
  }

  .placeholder-hero p {
    font-size: 1.25rem;
    color: var(--bufalo-cinza);
  }
</style>
