---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { seo } from '../../data/seo';
import { waMsg } from '../../data/whatsapp';
import CategoryGrid from '../../components/CategoryGrid.astro';
import CTASection from '../../components/CTASection.astro';
import StitchDivider from '../../components/StitchDivider.astro';
---

<BaseLayout title={seo.produtos.title} description={seo.produtos.description}>

  <!-- Page header -->
  <section class="produtos-hero">
    <div class="container">
      <h1 class="produtos-hero__title">Nossos Produtos</h1>
      <p class="produtos-hero__intro">
        Tudo para a sua costura, com a força da Búfalo. Escolha uma categoria e veja o que temos para a sua produção.
      </p>
    </div>
  </section>

  <StitchDivider ornament={false} />

  <!-- 8 category cards -->
  <CategoryGrid />

  <StitchDivider />

  <!-- Closing CTA -->
  <CTASection
    title="Compra em volume?"
    text="Atendemos confecções e revendedores em todo o Brasil. Fale direto no WhatsApp."
    buttonLabel="Falar no WhatsApp"
    waMessage={waMsg.atacado}
    variant="red"
  />

</BaseLayout>

<style>
  .produtos-hero {
    background-color: var(--bufalo-cinza);
    padding-block: 3.5rem;
  }

  .produtos-hero .container {
    text-align: center;
    max-width: 680px;
  }

  .produtos-hero__title {
    font-family: var(--font-titulo);
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.1;
    color: var(--bufalo-branco);
    margin-bottom: 0.9rem;
  }

  .produtos-hero__intro {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.65;
    margin: 0 auto;
    max-width: 560px;
  }
</style>
