---
import BaseLayout from '../layouts/BaseLayout.astro';
import { seo } from '../data/seo';
import { waMsg } from '../data/whatsapp';
import StitchDivider from '../components/StitchDivider.astro';
import CTASection from '../components/CTASection.astro';
---

<BaseLayout title={seo.qualidade.title} description={seo.qualidade.description}>

  <!-- 1. HEADER -->
  <section class="qual-hero">
    <div class="container">
      <h1 class="qual-hero__title">Por que costurar com Búfalo</h1>
    </div>
  </section>

  <StitchDivider ornament={false} />

  <!-- 2. OS 4 DIFERENCIAIS -->
  <section class="diferenciais">
    <div class="container">
      <ul class="diferenciais__grid" role="list">

        <li class="diferenciais__item">
          <span class="diferenciais__icon" aria-hidden="true">
            <!-- Shield -->
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <path d="M20 4L6 10v10c0 8.284 5.928 16.025 14 18 8.072-1.975 14-9.716 14-18V10L20 4z"
                stroke="currentColor" stroke-width="2.2" stroke-linejoin="round" fill="none"/>
              <path d="M14 20l4 4 8-8" stroke="currentColor" stroke-width="2.2"
                stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <h2 class="diferenciais__titulo">Resistência ao rompimento</h2>
          <p class="diferenciais__texto">
            A linha Búfalo é feita para aguentar. Alta velocidade, costura pesada, produção
            contínua: o ponto não cede.
          </p>
        </li>

        <li class="diferenciais__item">
          <span class="diferenciais__icon" aria-hidden="true">
            <!-- Sewing machine -->
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <rect x="6" y="14" width="28" height="16" rx="3" stroke="currentColor" stroke-width="2.2" fill="none"/>
              <circle cx="20" cy="22" r="4" stroke="currentColor" stroke-width="2" fill="none"/>
              <circle cx="20" cy="22" r="1.5" fill="currentColor"/>
              <path d="M20 10v4" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
              <line x1="6" y1="30" x2="34" y2="30" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <line x1="10" y1="30" x2="10" y2="34" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <line x1="30" y1="30" x2="30" y2="34" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </span>
          <h2 class="diferenciais__titulo">Para indústria e para ateliê</h2>
          <p class="diferenciais__texto">
            Desempenho comprovado em máquina industrial e doméstica. A mesma força para a
            grande confecção e para quem costura em casa.
          </p>
        </li>

        <li class="diferenciais__item">
          <span class="diferenciais__icon" aria-hidden="true">
            <!-- Palette -->
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <circle cx="13" cy="13" r="5" stroke="currentColor" stroke-width="2.2" fill="none"/>
              <circle cx="27" cy="13" r="5" stroke="currentColor" stroke-width="2.2" fill="none"/>
              <circle cx="20" cy="25" r="5" stroke="currentColor" stroke-width="2.2" fill="none"/>
              <circle cx="13" cy="13" r="2" fill="currentColor"/>
              <circle cx="27" cy="13" r="2" fill="currentColor"/>
              <circle cx="20" cy="25" r="2" fill="currentColor"/>
            </svg>
          </span>
          <h2 class="diferenciais__titulo">Variedade que resolve</h2>
          <p class="diferenciais__texto">
            Centenas de cores e um portfólio completo de aviamentos. Você encontra tudo num
            lugar só.
          </p>
        </li>

        <li class="diferenciais__item">
          <span class="diferenciais__icon" aria-hidden="true">
            <!-- Map pin -->
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <path d="M20 4C14.477 4 10 8.477 10 14c0 8.25 10 22 10 22s10-13.75 10-22c0-5.523-4.477-10-10-10z"
                stroke="currentColor" stroke-width="2.2" fill="none"/>
              <circle cx="20" cy="14" r="3.5" stroke="currentColor" stroke-width="2" fill="none"/>
              <path d="M9 34c0 0 3-2 11-2s11 2 11 2" stroke="currentColor" stroke-width="1.8"
                stroke-linecap="round" opacity="0.5"/>
            </svg>
          </span>
          <h2 class="diferenciais__titulo">Confiança nacional</h2>
          <p class="diferenciais__texto">
            Búfalo conquistou clientes de norte a sul do Brasil. Marca que o costureiro conhece
            e indica.
          </p>
        </li>

      </ul>
    </div>
  </section>

  <StitchDivider />

  <!-- 3. APLICAÇÕES -->
  <section class="aplicacoes">
    <div class="container">
      <h2 class="aplicacoes__heading">Onde a Búfalo é usada</h2>
      <ul class="aplicacoes__grid" role="list">
        <li class="aplicacoes__item">
          <strong class="aplicacoes__tipo">Confecção</strong>
          <span class="aplicacoes__desc">Produção em larga escala com alta velocidade de costura.</span>
        </li>
        <li class="aplicacoes__item">
          <strong class="aplicacoes__tipo">Ateliê</strong>
          <span class="aplicacoes__desc">Peças sob medida, acabamento impecável e precisão de costura.</span>
        </li>
        <li class="aplicacoes__item">
          <strong class="aplicacoes__tipo">Artesanato</strong>
          <span class="aplicacoes__desc">Centenas de cores para projetos criativos e personalizados.</span>
        </li>
        <li class="aplicacoes__item">
          <strong class="aplicacoes__tipo">Indústria</strong>
          <span class="aplicacoes__desc">Resistência e uniformidade para linhas de produção exigentes.</span>
        </li>
      </ul>
    </div>
  </section>

  <StitchDivider />

  <!-- 4. CTA -->
  <CTASection
    title="Fale com a gente no WhatsApp"
    text="Tire dúvidas, faça pedidos e descubra o produto certo para a sua produção."
    buttonLabel="Falar no WhatsApp"
    waMessage={waMsg.atacado}
    variant="red"
  />

</BaseLayout>

<style>
  /* ── HERO ── */
  .qual-hero {
    background-color: var(--bufalo-cinza);
    padding-block: 3.5rem;
    text-align: center;
  }

  .qual-hero__title {
    font-family: var(--font-titulo);
    font-size: clamp(1.9rem, 5vw, 3.2rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.15;
    color: var(--bufalo-branco);
    margin: 0;
  }

  /* ── DIFERENCIAIS ── */
  .diferenciais {
    padding-block: 3.5rem;
    background-color: var(--bufalo-branco);
  }

  .diferenciais__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .diferenciais__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .diferenciais__item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 1.75rem;
    background-color: var(--bufalo-cinza-claro);
    border-radius: var(--radius);
    border-left: 4px solid var(--bufalo-vermelho);
  }

  .diferenciais__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background-color: rgba(178, 34, 34, 0.08);
    color: var(--bufalo-vermelho);
    flex-shrink: 0;
  }

  .diferenciais__titulo {
    font-family: var(--font-titulo);
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--bufalo-cinza);
    margin: 0;
    line-height: 1.2;
  }

  .diferenciais__texto {
    font-size: 0.97rem;
    color: #555;
    line-height: 1.65;
    margin: 0;
  }

  /* ── APLICAÇÕES ── */
  .aplicacoes {
    padding-block: 3rem;
    background-color: var(--bufalo-cinza-claro);
  }

  .aplicacoes__heading {
    font-family: var(--font-titulo);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--bufalo-cinza);
    margin-bottom: 2rem;
    text-align: center;
  }

  .aplicacoes__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 480px) {
    .aplicacoes__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .aplicacoes__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .aplicacoes__item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    background-color: var(--bufalo-branco);
    border-radius: var(--radius);
    border-top: 3px solid var(--bufalo-vermelho);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    text-align: center;
  }

  .aplicacoes__tipo {
    font-family: var(--font-titulo);
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--bufalo-cinza);
  }

  .aplicacoes__desc {
    font-size: 0.88rem;
    color: #666;
    line-height: 1.5;
  }
</style>
